{
  "name": "cube",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Markdown wiki engine for Next.js apps",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    },
    "./react": {
      "types": "./src/react/index.tsx",
      "default": "./src/react/index.tsx"
    },
    "./editor": {
      "types": "./src/editor/index.ts",
      "default": "./src/editor/index.ts"
    },
    "./mcp": {
      "types": "./src/mcp/index.ts",
      "default": "./src/mcp/index.ts"
    },
    "./import/mediawiki": {
      "types": "./src/import/mediawiki/index.ts",
      "default": "./src/import/mediawiki/index.ts"
    },
    "./import/mediawiki/fetch": {
      "types": "./src/import/mediawiki/fetch.ts",
      "default": "./src/import/mediawiki/fetch.ts"
    }
  },
  "scripts": {
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "pg": ">=8",
    "react": ">=19"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tiptap/core": "^3.28.0",
    "@tiptap/extension-link": "^3.28.0",
    "@tiptap/extension-placeholder": "^3.28.0",
    "@tiptap/extension-table": "^3.28.0",
    "@tiptap/markdown": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@tiptap/suggestion": "^3.28.0",
    "acorn": "^8.14.0",
    "diff": "^9.0.0",
    "github-slugger": "^2.0.0",
    "hast-util-from-html": "^2.0.3",
    "hast-util-to-mdast": "^10.1.2",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-gfm": "^3.0.0",
    "mdast-util-mdx-jsx": "^3.1.3",
    "mdast-util-to-markdown": "^2.1.2",
    "micromark-extension-gfm": "^3.0.0",
    "micromark-extension-mdx-jsx": "^3.0.1",
    "node-diff3": "^3.1.2",
    "undici": "^7.28.0",
    "unist-util-visit": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^22",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "jsdom": "^29.1.1",
    "pg": "^8.21.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
