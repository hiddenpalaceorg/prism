<Window
    x:Class="PrismWin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrismWin">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="Root" AllowDrop="True" DragOver="Root_DragOver" Drop="Root_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Custom title bar (content extends into it; see constructor). -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="34">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="14,0,0,0" VerticalAlignment="Center">
                <Image Source="ms-appx:///Assets/prism.ico" Width="16" Height="16" />
                <TextBlock Text="Prism" Style="{StaticResource CaptionTextBlockStyle}" />
            </StackPanel>
        </Grid>

        <MenuBar Grid.Row="1" Margin="6,0,0,0">
            <MenuBarItem Title="File">
                <MenuFlyoutItem x:Name="MenuOpen" Text="Open Image..." Click="MenuOpen_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="O" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="MenuOpenFolderAsBuild" Text="Open Folder as Build..." Click="MenuOpenFolderAsBuild_Click" />
                <MenuFlyoutItem x:Name="MenuReanalyze" Text="Re-analyze Image (fresh)..." Click="MenuReanalyze_Click" />
                <MenuFlyoutItem x:Name="MenuImportFolder" Text="Import Folder (recursive)..." Click="MenuImportFolder_Click" />
                <MenuFlyoutSubItem x:Name="RecentSubmenu" Text="Open Recent" />
                <MenuFlyoutItem x:Name="MenuBrowseLibrary" Text="Browse Library" Click="MenuBrowseLibrary_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="B" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="MenuExport" Text="Export Library for Upload..." Click="MenuExport_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Exit" Click="MenuExit_Click" />
            </MenuBarItem>
            <MenuBarItem Title="View">
                <MenuFlyoutItem Text="Overview" Click="MenuViewOverview_Click" />
                <MenuFlyoutItem Text="Assets" Click="MenuViewAssets_Click" />
                <MenuFlyoutItem Text="DAT / JSON" Click="MenuViewDocument_Click" />
                <MenuFlyoutItem Text="Similar" Click="MenuViewSimilar_Click" />
            </MenuBarItem>
            <MenuBarItem Title="Analysis">
                <MenuFlyoutItem x:Name="MenuCancel" Text="Cancel" IsEnabled="False" Click="MenuCancel_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="MenuSimilar" Text="Find Similar" Click="MenuSimilar_Click" />
                <MenuFlyoutItem x:Name="MenuSubmit" Text="Submit Build..." Click="MenuSubmit_Click" />
            </MenuBarItem>
        </MenuBar>

        <Grid Grid.Row="2">
            <!-- Build mode: filesystem tree + detail tabs. -->
            <Grid x:Name="BuildPane">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" MinWidth="220" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" BorderThickness="0,0,1,0"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                    <TreeView x:Name="FsTree" SelectionMode="Single" ItemInvoked="FsTree_ItemInvoked"
                              Margin="4,4,0,0">
                        <TreeView.ItemTemplate>
                            <DataTemplate x:DataType="local:DiscNodeVm">
                                <TreeViewItem ItemsSource="{x:Bind Children}" IsExpanded="{x:Bind IsRoot}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="{x:Bind Glyph}" FontSize="13"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{x:Bind Name}" />
                                    </StackPanel>
                                </TreeViewItem>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                    <StackPanel x:Name="TreeEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Spacing="10" Padding="24">
                        <FontIcon Glyph="&#xE958;" FontSize="40"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock Text="No image loaded" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Open — or drag in — a disc image, container, or folder."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel x:Name="HeaderCard" Grid.Row="0" Margin="16,10,16,6" Spacing="6"
                                Visibility="Collapsed">
                        <TextBlock x:Name="HeaderTitle" Style="{StaticResource SubtitleTextBlockStyle}"
                                   IsTextSelectionEnabled="True" />
                        <StackPanel x:Name="HeaderTags" Orientation="Horizontal" Spacing="8" />
                        <TextBlock x:Name="HeaderSha" FontFamily="Consolas" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   IsTextSelectionEnabled="True" />
                    </StackPanel>

                    <SelectorBar x:Name="TabBar" Grid.Row="1" Margin="12,0,12,0"
                                 SelectionChanged="TabBar_SelectionChanged">
                        <SelectorBarItem x:Name="TabOverview" Text="Overview" />
                        <SelectorBarItem x:Name="TabSelection" Text="Selection" />
                        <SelectorBarItem x:Name="TabAssets" Text="Assets" />
                        <SelectorBarItem x:Name="TabDocument" Text="DAT / JSON" />
                        <SelectorBarItem x:Name="TabSimilar" Text="Similar" />
                    </SelectorBar>

                    <Grid Grid.Row="2">
                        <ScrollViewer x:Name="OverviewScroll">
                            <StackPanel x:Name="OverviewPanel" Margin="16,10,16,16" Spacing="12" />
                        </ScrollViewer>
                        <ScrollViewer x:Name="SelectionScroll" Visibility="Collapsed">
                            <StackPanel x:Name="SelectionPanel" Margin="16,10,16,16" Spacing="12" />
                        </ScrollViewer>
                        <ScrollViewer x:Name="AssetsScroll" Visibility="Collapsed">
                            <StackPanel x:Name="AssetsPanel" Margin="16,10,16,16" Spacing="8" />
                        </ScrollViewer>
                        <Grid x:Name="DocPane" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <SelectorBar x:Name="DocModeBar" Margin="16,8,16,0"
                                         SelectionChanged="DocModeBar_SelectionChanged">
                                <SelectorBarItem x:Name="DocModeXml" Text="XML" />
                                <SelectorBarItem x:Name="DocModeJson" Text="JSON" />
                            </SelectorBar>
                            <TextBox x:Name="DocText" Grid.Row="1" IsReadOnly="True" AcceptsReturn="True"
                                     TextWrapping="NoWrap" FontFamily="Consolas" FontSize="12"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     BorderThickness="0" Background="Transparent" Margin="8" />
                        </Grid>
                        <Grid x:Name="SimilarPane" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,10,16,4">
                                <Button x:Name="FindSimilarBtn" Content="Find Similar" Click="MenuSimilar_Click" />
                                <Button x:Name="SubmitBtn" Content="Submit..." Click="MenuSubmit_Click" />
                                <ProgressRing x:Name="QueryRing" IsActive="False" Width="18" Height="18" />
                            </StackPanel>
                            <ScrollViewer Grid.Row="1">
                                <StackPanel x:Name="SimilarPanel" Margin="16,6,16,16" Spacing="12" />
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Library mode: searchable, sortable list of every analyzed build. -->
            <Grid x:Name="LibraryPane" Visibility="Collapsed" Margin="12,8,12,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" PlaceholderText="Search title or system"
                             TextChanged="SearchBox_TextChanged" />
                    <ComboBox x:Name="SystemFilter" Grid.Column="1" MinWidth="180"
                              SelectionChanged="SystemFilter_SelectionChanged" />
                </Grid>
                <Grid x:Name="LibraryHeaderGrid" Grid.Row="1" Margin="12,10,12,2" />
                <ListView x:Name="LibraryList" Grid.Row="2" IsItemClickEnabled="True"
                          SelectionMode="None" ItemClick="LibraryList_ItemClick">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:LibraryRowVm">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{x:Bind System}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="2" Text="{x:Bind FilesText}" TextAlignment="Right"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="3" Text="{x:Bind SizeText}" TextAlignment="Right"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="4" Text="{x:Bind DateText}" TextAlignment="Right"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock x:Name="LibCountFooter" Grid.Row="3" Margin="12,4,12,4" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>
        </Grid>

        <!-- Status bar: live counters + status line. -->
        <Grid Grid.Row="3" BorderThickness="0,1,0,0" Padding="12,6,12,8"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel x:Name="CountersPanel" Spacing="4" Margin="0,0,0,4" />
            <Grid Grid.Row="1" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressRing x:Name="BusyRing" IsActive="False" Width="16" Height="16" />
                <TextBlock x:Name="StatusText" Grid.Column="1" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Text="Open — or drag in — a disc image, container, or folder." />
                <TextBlock x:Name="ServiceText" Grid.Column="2" VerticalAlignment="Center" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextTrimming="CharacterEllipsis" MaxWidth="420" />
                <TextBlock x:Name="LibCountText" Grid.Column="3" VerticalAlignment="Center" FontSize="12"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            </Grid>
        </Grid>

        <!-- In-app asset viewer overlay (image / media / text / hex). -->
        <Grid x:Name="PreviewOverlay" Grid.Row="0" Grid.RowSpan="4" Visibility="Collapsed"
              Background="#A0000000">
            <Border MaxWidth="960" MaxHeight="720" Margin="40" Padding="16" CornerRadius="8"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PreviewTitle" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="1" Click="PreviewClose_Click" Padding="6">
                            <FontIcon Glyph="&#xE711;" FontSize="12" />
                        </Button>
                    </Grid>
                    <Grid x:Name="PreviewHost" Grid.Row="1" MinWidth="480" MinHeight="240" />
                    <Grid Grid.Row="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PreviewNote" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Button x:Name="PreviewCopyBtn" Grid.Column="1" Content="Copy"
                                Click="PreviewCopy_Click" />
                        <Button x:Name="PreviewOpenExternalBtn" Grid.Column="2" Content="Open Externally"
                                Click="PreviewOpenExternal_Click" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
