<Window
    x:Class="PrismWin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PrismWin">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="Root" AllowDrop="True" DragOver="Root_DragOver" Drop="Root_Drop">
        <Grid.Resources>
            <!-- Virtualized monospace lines for big text/hex previews: one
                 TextBlock per line in a ListView stays smooth where a single
                 quarter-megabyte TextBlock would freeze layout. -->
            <DataTemplate x:Key="MonoLineTemplate">
                <TextBlock Text="{Binding}" FontFamily="Cascadia Mono,Consolas" FontSize="12"
                           IsTextSelectionEnabled="True" TextWrapping="Wrap" />
            </DataTemplate>
            <Style x:Key="MonoLineContainer" TargetType="ListViewItem">
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Padding" Value="2,0,2,0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Custom title bar (content extends into it; see constructor). -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="34">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="14,0,0,0" VerticalAlignment="Center">
                <Image Source="ms-appx:///Assets/prism.ico" Width="16" Height="16" />
                <TextBlock Text="Prism" Style="{StaticResource CaptionTextBlockStyle}" />
            </StackPanel>
        </Grid>

        <MenuBar Grid.Row="1" Margin="6,0,0,0">
            <MenuBarItem Title="File">
                <MenuFlyoutItem x:Name="MenuOpen" Text="Open Image..." Click="MenuOpen_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="O" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="MenuOpenFolderAsBuild" Text="Open Folder as Build..." Click="MenuOpenFolderAsBuild_Click" />
                <MenuFlyoutItem x:Name="MenuReanalyze" Text="Re-analyze Image (fresh)..." Click="MenuReanalyze_Click" />
                <MenuFlyoutItem x:Name="MenuImportFolder" Text="Import Folder (recursive)..." Click="MenuImportFolder_Click" />
                <MenuFlyoutSubItem x:Name="RecentSubmenu" Text="Open Recent" />
                <MenuFlyoutItem x:Name="MenuBrowseLibrary" Text="Browse Library" Click="MenuBrowseLibrary_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="B" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="MenuExport" Text="Export Library for Upload..." Click="MenuExport_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Exit" Click="MenuExit_Click" />
            </MenuBarItem>
            <MenuBarItem Title="View">
                <MenuFlyoutItem Text="Overview" Click="MenuViewOverview_Click" />
                <MenuFlyoutItem Text="Assets" Click="MenuViewAssets_Click" />
                <MenuFlyoutItem Text="DAT / JSON" Click="MenuViewDocument_Click" />
                <MenuFlyoutItem Text="Similar" Click="MenuViewSimilar_Click" />
            </MenuBarItem>
            <MenuBarItem Title="Analysis">
                <MenuFlyoutItem x:Name="MenuCancel" Text="Cancel" IsEnabled="False" Click="MenuCancel_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="MenuSimilar" Text="Find Similar" Click="MenuSimilar_Click" />
                <MenuFlyoutItem x:Name="MenuSubmit" Text="Submit Build..." Click="MenuSubmit_Click" />
            </MenuBarItem>
        </MenuBar>

        <Grid Grid.Row="2">
            <!-- Build mode: filesystem tree on Mica at left, detail views in a
                 rounded layer card at right (the Windows 11 Settings layout). -->
            <Grid x:Name="BuildPane">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="TreeColumn" Width="280" MinWidth="200" MaxWidth="560" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="8,0,0,8">
                    <TreeView x:Name="FsTree" SelectionMode="Single" ItemInvoked="FsTree_ItemInvoked"
                              Margin="0,4,0,0">
                        <TreeView.ItemTemplate>
                            <DataTemplate x:DataType="local:DiscNodeVm">
                                <TreeViewItem ItemsSource="{x:Bind Children}" IsExpanded="{x:Bind IsRoot}">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon Glyph="{x:Bind Glyph}" FontSize="14"
                                                  VerticalAlignment="Center"
                                                  Foreground="{x:Bind IconBrush}" />
                                        <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </TreeViewItem>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                    <StackPanel x:Name="TreeEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Spacing="10" Padding="24">
                        <Border Width="56" Height="56" CornerRadius="28" HorizontalAlignment="Center"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                            <FontIcon Glyph="&#xE958;" FontSize="24"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        </Border>
                        <TextBlock Text="No image loaded" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="The build's filesystem shows here."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>
                </Grid>

                <!-- Invisible drag strip in the gutter between the panes. -->
                <local:SizerBar Grid.Column="1" Background="Transparent" Margin="0,4,0,8"
                                PointerPressed="TreeSizer_PointerPressed"
                                PointerMoved="TreeSizer_PointerMoved"
                                PointerReleased="TreeSizer_PointerReleased"
                                PointerCaptureLost="TreeSizer_PointerCaptureLost" />

                <Border Grid.Column="2" Margin="0,4,16,8" CornerRadius="8"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- System-tinted wash bleeding down from the hero. The
                             stops are recolored per detected system in code. -->
                        <Rectangle x:Name="HeaderWash" Grid.Row="0" Grid.RowSpan="2" RadiusX="8" RadiusY="8"
                                   IsHitTestVisible="False">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop x:Name="WashStopA" Color="#008B5CF6" Offset="0" />
                                    <GradientStop x:Name="WashStopB" Color="#003B82F6" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <Grid x:Name="HeaderCard" Grid.Row="0" Margin="20,18,20,6" ColumnSpacing="16"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="64" Height="64" CornerRadius="14" VerticalAlignment="Top">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop x:Name="TileStopA" Color="#FF8B5CF6" Offset="0" />
                                        <GradientStop x:Name="TileStopB" Color="#FF3B82F6" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <FontIcon Glyph="&#xE958;" FontSize="28" Foreground="White" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="7" VerticalAlignment="Center">
                                <TextBlock x:Name="HeaderTitle" Style="{StaticResource SubtitleTextBlockStyle}"
                                           FontSize="26" TextTrimming="CharacterEllipsis"
                                           IsTextSelectionEnabled="True" />
                                <StackPanel x:Name="HeaderTags" Orientation="Horizontal" Spacing="6" />
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock x:Name="HeaderSha" FontFamily="Cascadia Mono,Consolas" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               IsTextSelectionEnabled="True" VerticalAlignment="Center" />
                                    <Button x:Name="HeaderShaCopy" Click="HeaderShaCopy_Click" Padding="5,2"
                                            Background="Transparent" BorderThickness="0"
                                            ToolTipService.ToolTip="Copy SHA-256">
                                        <FontIcon Glyph="&#xE8C8;" FontSize="12"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <SelectorBar x:Name="TabBar" Grid.Row="1" Margin="16,2,16,0" Visibility="Collapsed"
                                     SelectionChanged="TabBar_SelectionChanged">
                            <SelectorBarItem x:Name="TabOverview" Text="Overview" />
                            <SelectorBarItem x:Name="TabSelection" Text="Selection" />
                            <SelectorBarItem x:Name="TabAssets" Text="Assets" />
                            <SelectorBarItem x:Name="TabDocument" Text="DAT / JSON" />
                            <SelectorBarItem x:Name="TabSimilar" Text="Similar" />
                        </SelectorBar>

                        <Grid Grid.Row="2">
                            <ScrollViewer x:Name="OverviewScroll">
                                <StackPanel x:Name="OverviewPanel" Margin="20,12,20,20" Spacing="12">
                                    <StackPanel.ChildrenTransitions>
                                        <TransitionCollection>
                                            <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="24" />
                                        </TransitionCollection>
                                    </StackPanel.ChildrenTransitions>
                                </StackPanel>
                            </ScrollViewer>
                            <ScrollViewer x:Name="SelectionScroll" Visibility="Collapsed">
                                <StackPanel x:Name="SelectionPanel" Margin="20,12,20,20" Spacing="12" />
                            </ScrollViewer>
                            <ScrollViewer x:Name="AssetsScroll" Visibility="Collapsed">
                                <StackPanel x:Name="AssetsPanel" Margin="20,8,20,20" Spacing="8" />
                            </ScrollViewer>
                            <Grid x:Name="DocPane" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Margin="20,10,20,8" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <SelectorBar x:Name="DocModeBar"
                                                 SelectionChanged="DocModeBar_SelectionChanged">
                                        <SelectorBarItem x:Name="DocModeXml" Text="XML" />
                                        <SelectorBarItem x:Name="DocModeJson" Text="JSON" />
                                    </SelectorBar>
                                    <Button x:Name="DocCopyBtn" Grid.Column="1" Click="DocCopy_Click"
                                            Padding="9,5" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                                            <TextBlock Text="Copy" FontSize="12" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <TextBlock x:Name="DocTruncNote" Grid.Row="1" Margin="20,0,20,6"
                                           FontSize="12" Visibility="Collapsed"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <!-- Always-dark terminal card: the vivid palette
                                     needs the dark surface in both app themes. -->
                                <Border Grid.Row="2" Margin="20,0,20,16" CornerRadius="8"
                                        Background="#FF1E1F26" BorderBrush="#26FFFFFF"
                                        BorderThickness="1" RequestedTheme="Dark">
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto" Padding="16,12,16,14">
                                        <RichTextBlock x:Name="DocRich" FontFamily="Cascadia Mono,Consolas"
                                                       FontSize="12" TextWrapping="NoWrap"
                                                       Foreground="#FFD4D4D4"
                                                       IsTextSelectionEnabled="True" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                            <Grid x:Name="SimilarPane" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="20,12,20,4">
                                    <Button x:Name="FindSimilarBtn" Style="{StaticResource AccentButtonStyle}"
                                            Click="MenuSimilar_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <FontIcon Glyph="&#xE721;" FontSize="13" />
                                            <TextBlock Text="Find Similar" />
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="SubmitBtn" Content="Submit..." Click="MenuSubmit_Click" />
                                    <ProgressRing x:Name="QueryRing" IsActive="False" Width="18" Height="18" />
                                </StackPanel>
                                <ScrollViewer Grid.Row="1">
                                    <StackPanel x:Name="SimilarPanel" Margin="20,6,20,20" Spacing="8">
                                        <StackPanel.ChildrenTransitions>
                                            <TransitionCollection>
                                                <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="24" />
                                            </TransitionCollection>
                                        </StackPanel.ChildrenTransitions>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                            <StackPanel x:Name="DetailEmptyState" VerticalAlignment="Center"
                                        HorizontalAlignment="Center" Spacing="12" Padding="32">
                                <Border Width="88" Height="88" CornerRadius="44" HorizontalAlignment="Center"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                    <Image Source="ms-appx:///Assets/prism.ico" Width="44" Height="44" />
                                </Border>
                                <TextBlock Text="Drop a disc image to get started"
                                           Style="{StaticResource SubtitleTextBlockStyle}"
                                           HorizontalAlignment="Center" Margin="0,6,0,0" />
                                <TextBlock Text="Prism analyzes disc images, containers, and folders, extracts their assets, and matches them against the library."
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400" />
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center"
                                            Margin="0,8,0,0">
                                    <Button Style="{StaticResource AccentButtonStyle}" Click="MenuOpen_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                                            <TextBlock Text="Open Image" />
                                        </StackPanel>
                                    </Button>
                                    <Button Click="MenuBrowseLibrary_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE8F1;" FontSize="14" />
                                            <TextBlock Text="Browse Library" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Library mode: search row on Mica, the list in a layer card. -->
            <Grid x:Name="LibraryPane" Visibility="Collapsed" Margin="16,6,16,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <AutoSuggestBox x:Name="SearchBox" QueryIcon="Find"
                                    PlaceholderText="Search title or system"
                                    TextChanged="SearchBox_TextChanged" />
                    <ComboBox x:Name="SystemFilter" Grid.Column="1" MinWidth="180"
                              SelectionChanged="SystemFilter_SelectionChanged" />
                </Grid>
                <Border Grid.Row="1" Margin="0,10,0,0" CornerRadius="8"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid x:Name="LibraryHeaderGrid" Grid.Row="0" Margin="20,10,20,8" />
                        <Border Grid.Row="1" Height="1"
                                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <ListView x:Name="LibraryList" Grid.Row="2" Padding="8,6,8,6"
                                  IsItemClickEnabled="True" SelectionMode="None"
                                  ItemClick="LibraryList_ItemClick">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:LibraryRowVm">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="88" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="6"
                                                Background="{x:Bind ChipBrush}" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE958;" FontSize="13"
                                                      Foreground="{x:Bind ChipIconBrush}" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind System}" VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="3" Text="{x:Bind FilesText}" TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="4" Text="{x:Bind SizeText}" TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="5" Text="{x:Bind DateText}" TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <StackPanel x:Name="LibraryEmptyState" Grid.Row="2" Visibility="Collapsed"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Spacing="10" Padding="24">
                            <Border Width="56" Height="56" CornerRadius="28" HorizontalAlignment="Center"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <FontIcon Glyph="&#xE8F1;" FontSize="22"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            </Border>
                            <TextBlock x:Name="LibraryEmptyTitle" Style="{StaticResource BodyStrongTextBlockStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="LibraryEmptyHint"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" TextAlignment="Center" MaxWidth="360" />
                        </StackPanel>
                        <Border Grid.Row="3" BorderThickness="0,1,0,0"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                            <TextBlock x:Name="LibCountFooter" Margin="20,6,20,8" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Status bar: live counters + status line. -->
        <Grid Grid.Row="3" BorderThickness="0,1,0,0" Padding="16,7,16,9"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel x:Name="CountersPanel" Spacing="4" Margin="0,0,0,4" />
            <Grid Grid.Row="1" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressRing x:Name="BusyRing" IsActive="False" Width="16" Height="16" />
                <TextBlock x:Name="StatusText" Grid.Column="1" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Text="Open — or drag in — a disc image, container, or folder." />
                <TextBlock x:Name="ServiceText" Grid.Column="2" VerticalAlignment="Center" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextTrimming="CharacterEllipsis" MaxWidth="420" />
                <TextBlock x:Name="LibCountText" Grid.Column="3" VerticalAlignment="Center" FontSize="12"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            </Grid>
        </Grid>

        <!-- In-app asset viewer overlay (image / media / text / hex). -->
        <Grid x:Name="PreviewOverlay" Grid.Row="0" Grid.RowSpan="4" Visibility="Collapsed"
              Background="{ThemeResource SmokeFillColorDefaultBrush}">
            <Border MaxWidth="980" MaxHeight="740" Margin="40" Padding="20" CornerRadius="12"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PreviewTitle" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="1" Click="PreviewClose_Click" Padding="6"
                                Background="Transparent" BorderThickness="0">
                            <FontIcon Glyph="&#xE711;" FontSize="12" />
                        </Button>
                    </Grid>
                    <Grid x:Name="PreviewHost" Grid.Row="1" MinWidth="480" MinHeight="240" />
                    <Grid Grid.Row="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PreviewNote" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Button x:Name="PreviewCopyBtn" Grid.Column="1" Content="Copy"
                                Click="PreviewCopy_Click" />
                        <Button x:Name="PreviewOpenExternalBtn" Grid.Column="2" Content="Open Externally"
                                Click="PreviewOpenExternal_Click" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
